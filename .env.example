# =============================================================================
# Database — PostgreSQL (required)
# =============================================================================
DB_USER=postgres
DB_PASS=changeme
DB_HOST=localhost
DB_PORT=5432
DB_NAME=monolog
DB_DATA=./pgdata

# =============================================================================
# JWT / Auth (SECRET_KEY is required — generate with: openssl rand -hex 32)
# =============================================================================
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Cookie Settings
# =============================================================================
COOKIE_SECURE=False
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/
COOKIE_MAX_AGE_DAYS=7
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_HTTPONLY=True
REFRESH_TOKEN_COOKIE_SECURE=False
REFRESH_TOKEN_COOKIE_SAMESITE=lax
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_BYTES=32

# =============================================================================
# Valkey / Redis Cache
# =============================================================================
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_DB=0
VALKEY_PASSWORD=

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_SECONDS=900

# =============================================================================
# TMDB — Movie metadata API (https://www.themoviedb.org/settings/api)
# =============================================================================
TMDB_API_KEY=

# =============================================================================
# SMTP — Email sending
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_USE_TLS=True
SMTP_USE_SSL=False
EMAIL_VERIFICATION_TTL_MINUTES=10

# =============================================================================
# S3 / Object Storage — Profile images
# =============================================================================
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=profile-images
S3_REGION=us-east-1
S3_PUBLIC_URL=
S3_USE_PATH_STYLE=False

# =============================================================================
# Server
# =============================================================================
WEB_CONCURRENCY=1
